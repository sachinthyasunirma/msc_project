# Core
NODE_ENV=development
PORT=3000

# Data
DATABASE_URL=postgres://user:password@host:5432/db
REDIS_URL=redis://localhost:6379

# Logging
LOG_APP_NAME=msc-saas
LOG_SERVICE_NAME=web
LOG_LEVEL=info
LOG_PRETTY=true
LOG_RELEASE=local-dev
LOG_PROFILE_OPERATIONS=false
LOG_SLOW_OPERATION_MS=250
LOG_MAX_FIELD_LENGTH=500
LOG_MAX_ARRAY_LENGTH=20
LOG_MAX_OBJECT_KEYS=50

